1.boolean isAnagram(String s, String t) {
    if (s.length() != t.length()) return false;
    int[] count = new int[26];
    for (char c : s.toCharArray()) count[c - 'a']++;
    for (char c : t.toCharArray()) count[c - 'a']--;
    for (int i : count) if (i != 0) return false;
    return true;
}
3. Teemo Attack - Poison Duration
int findPoisonedDuration(int[] timeSeries, int duration) {
    int total = 0;
    for (int i = 0; i < timeSeries.length; i++) {
        if (i == timeSeries.length - 1) total += duration;
        else total += Math.min(duration, timeSeries[i + 1] - timeSeries[i]);
    }
    return total;
}
4. Text Compression (Run-Length Encoding)
static class Task {

    public int compress(char[] chars) {
        int write = 0;
        int i = 0;

        while (i < chars.length) {
            char current = chars[i];
            int count = 0;

            while (i < chars.length && chars[i] == current) {
                i++;
                count++;
            }

            chars[write++] = current;

            if (count > 1) {
                String s = count + "";
                for (char c : s.toCharArray()) {
                    chars[write++] = c;
                }
            }
        }

        return write;
    }
}

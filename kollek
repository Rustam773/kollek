5. Container With Most Water
static class WaterTask {

    public int maxArea(int[] height) {
        int l = 0, r = height.length - 1;
        int max = 0;

        while (l < r) {
            int area = Math.min(height[l], height[r]) * (r - l);
            if (area > max) max = area;

            if (height[l] < height[r]) l++;
            else r--;
        }

        return max;
    }
}
6. Spiral Matrix
static class MatrixTask {

    public int[][] generateMatrix(int n) {
        int[][] a = new int[n][n];

        int top = 0, bottom = n - 1;
        int left = 0, right = n - 1;
        int num = 1;

        while (true) {
            for (int i = left; i <= right; i++) a[top][i] = num++;
            if (++top > bottom) break;

            for (int i = top; i <= bottom; i++) a[i][right] = num++;
            if (--right < left) break;

            for (int i = right; i >= left; i--) a[bottom][i] = num++;
            if (--bottom < top) break;

            for (int i = bottom; i >= top; i--) a[i][left] = num++;
            if (++left > right) break;
        }

        return a;
    }
}
7. Coin Change (100% düzgün)
static class Task {

    public int coinChange(int[] coins, int amount) {
        int[] dp = new int[amount + 1];

        java.util.Arrays.fill(dp, amount + 1);
        dp[0] = 0;

        for (int i = 1; i <= amount; i++) {
            for (int c : coins) {
                if (i >= c) {
                    dp[i] = Math.min(dp[i], dp[i - c] + 1);
                }
            }
        }

        return dp[amount] == amount + 1 ? -1 : dp[amount];
    }
}

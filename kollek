14. ATM - Payment
static class ATMTask {

    public String calculateATM(int amount) {
        int[] notes = {100, 50, 20, 10, 5, 1};
        StringBuilder res = new StringBuilder();

        for (int n : notes) {
            while (amount >= n) {
                res.append(n).append(",");
                amount -= n;
            }
        }

        if (res.length() > 0) {
            res.setLength(res.length() - 1);
        }

        return res.toString();
    }
}
